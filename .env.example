# ═══════════════════════════════════════════════════════════════
# JARVIS - Environment Configuration (Template)
# Copiar a .env y llenar los valores
# ═══════════════════════════════════════════════════════════════

# LLM Provider: ollama, bedrock, lm_studio
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL_ID=minimax-m2.7
OLLAMA_API_KEY=

# Groq STT (para voz backend)
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# Piper TTS (para voz backend)
PIPER_MODEL_PATH=data/voices/es_ES-davefx-medium.onnx

# Data / Storage
DATA_DIR=data
STORAGE_TYPE=sqlite

# Context
MAX_CONTEXT_MESSAGES=50

# CORS
CORS_ORIGINS=["*"]

# API
API_HOST=0.0.0.0
API_PORT=8000

# Web Search
TAVILY_API_KEY=

# Railway Object Storage (S3-compatible)
# RAILWAY_BUCKET_NAME=
# RAILWAY_BUCKET_ENDPOINT=
# RAILWAY_BUCKET_ACCESS_KEY=
# RAILWAY_BUCKET_SECRET_KEY=
