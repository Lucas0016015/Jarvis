# AWS / Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5

# Ollama (Local or Cloud)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_API_KEY=

# LM Studio (OpenAI-compatible local LLM)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# LLM Provider: "ollama", "bedrock", or "lm_studio"
LLM_PROVIDER=ollama

# Memory
MAX_CONTEXT_MESSAGES=50

# Web Search (Tavily API key — optional, falls back to DuckDuckGo)
TAVILY_API_KEY=

# Observability (LangSmith — optional)
ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=

# Storage
DATA_DIR=data

# Gmail (Phase 2 — optional)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Google Calendar
GCAL_TOKEN_FILE=gcal_token.json

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# ── Security & Auth (NEW) ─────────────────────────────────────
# IMPORTANT: Change JWT_SECRET_KEY to a random 32+ char string in production
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256

# ── Rate Limiting (NEW) ─────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_AGENT=20/minute

# ── Railway Deployment ─────────────────────────────────────
RAILWAY_PUBLIC_DOMAIN=$RAILWAY_PUBLIC_DOMAIN
PORT=$PORT

# ── S3 Backup (Backblaze B2, Cloudflare R2, AWS S3) ────────
S3_PROVIDER=backblaze
S3_BUCKET=your-bucket-name
S3_REGION=us-west-002
S3_ENDPOINT=
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PREFIX=jarvis-backups
